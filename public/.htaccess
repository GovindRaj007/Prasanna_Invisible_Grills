# =====================================================================
# SECURITY & PERFORMANCE CONFIGURATION FOR PRASANNA INVISIBLE GRILLS
# =====================================================================
# Hostinger Static File Hosting - Apache Server Configuration
# Deploy in /public_html/ root directory

# =====================================================================
# CORE URL REWRITING - SPA ROUTING
# =====================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www if present
    RewriteCond %{HTTP_HOST} ^www\.
    RewriteRule ^(.*)$ https://%{HTTP_HOST:www.}/$1 [R=301,L]

    # Redirect old service URLs to new clean structure
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^service/invisible-grills/?$ /invisible-grills [R=301,L]
    RewriteRule ^service/invisible-grills-balcony/?$ /invisible-grills-balcony [R=301,L]
    RewriteRule ^service/invisible-grills-windows/?$ /invisible-grills-windows [R=301,L]
    RewriteRule ^service/invisible-grills-dealer/?$ /invisible-grills-dealer [R=301,L]
    RewriteRule ^service/ceiling-cloth-hanger/?$ /ceiling-cloth-hanger [R=301,L]
    RewriteRule ^services/invisible-grills/?$ /invisible-grills [R=301,L]
    RewriteRule ^services/invisible-grills-balcony/?$ /invisible-grills-balcony [R=301,L]
    RewriteRule ^services/invisible-grills-windows/?$ /invisible-grills-windows [R=301,L]
    RewriteRule ^services/invisible-grills-dealer/?$ /invisible-grills-dealer [R=301,L]
    RewriteRule ^services/ceiling-cloth-hanger/?$ /ceiling-cloth-hanger [R=301,L]
    RewriteRule ^locations/invisible-grills-(.+)/?$ /invisible-grills-$1 [R=301,L]
    RewriteRule ^location/invisible-grills-(.+)/?$ /invisible-grills-$1 [R=301,L]
    RewriteRule ^service-location/(.+)/?$ /$1 [R=301,L]

    # SPA Routing: Send all requests to index.html except for existing files/folders
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [QSA,L]
</IfModule>

# =====================================================================
# SECURITY HEADERS
# =====================================================================
<IfModule mod_headers.c>
    # Content Security Policy - Allow images from self and HTTPS sources
    Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https: https://www.google-analytics.com https://www.googletagmanager.com https://analytics.google.com; frame-src https://www.googletagmanager.com; frame-ancestors 'none'; base-uri 'self';"

    # Prevent clickjacking attacks
    Header set X-Frame-Options "DENY"

    # Prevent MIME type sniffing
    Header set X-Content-Type-Options "nosniff"

    # Enable XSS protection in older browsers
    Header set X-XSS-Protection "1; mode=block"

    # Force HTTPS for one year including subdomains
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Referrer Policy - Reduce referrer information
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy - Restrict access to device features
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Remove sensitive headers
    Header unset Server
    Header unset X-Powered-By
    Header unset X-AspNet-Version
    Header set X-Permitted-Cross-Domain-Policies "none"
</IfModule>

# =====================================================================
# IMAGE SECURITY - HOTLINK PROTECTION ONLY
# =====================================================================
<IfModule mod_rewrite.c>
    # Block external hotlinks but allow same-domain and direct access
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?prasannainvisible\.in [NC]
    RewriteCond %{REQUEST_URI} \.(jpg|jpeg|png|gif|webp|svg)$ [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# =====================================================================
# PROPER IMAGE CACHING (NO ATTACHMENT HEADERS - ALLOW DISPLAY)
# =====================================================================
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    <IfModule mod_headers.c>
        # IMPORTANT: Allow images to display inline (NOT as attachments)
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# =====================================================================
# FILE PROTECTION & SECURITY
# =====================================================================

# Disable directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Hide .htaccess and configuration files
<FilesMatch "^\.ht">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to environment files
<Files ~ "\.env.*$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Prevent access to sensitive files
<FilesMatch "(^#.*#|\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# =====================================================================
# BROWSER CACHING STRATEGY
# =====================================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Static assets - Cache 1 year
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/woff "access plus 1 year"
    ExpiresByType application/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"

    # HTML should not be cached (SPA entry point)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =====================================================================
# GZIP COMPRESSION
# =====================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# =====================================================================
# DEFAULT DIRECTORY
# =====================================================================
DirectoryIndex index.html index.htm
    <IfModule mod_headers.c>
        # Force download as attachment instead of inline viewing
        Header set Content-Disposition "inline; filename=\"image\""
        # Cache-Control for browser cache
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

# =====================================================================
# BROWSER CACHING STRATEGY
# =====================================================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Static assets (versioned by hash in filename) - Cache 1 year
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType application/woff "access plus 1 year"
    ExpiresByType application/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"

    # HTML file (SPA entry) - No cache for index.html
    ExpiresByType text/html "access plus 0 seconds"
    DefaultType "text/html"
</IfModule>

# Alternative cache-control headers
<FilesMatch "\.(?:ico|css|js|gif|jpe?g|png|svg|webp|woff2?|ttf|otf)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>

<FilesMatch "\.html?$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </IfModule>
</FilesMatch>

# =====================================================================
# GZIP COMPRESSION - Reduce transfer size
# =====================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml+rss
</IfModule>

# =====================================================================
# ADDITIONAL SECURITY
# =====================================================================

# Disable directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Hide .htaccess and .htpasswd files
<FilesMatch "^\.ht">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to sensitive files
<FilesMatch "^(package\.json|\.env|\.env\.local|README|LICENSE|\.git)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
