# ============================================
# 301 REDIRECTS - Phase 2 SEO URL Structure
# ============================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Redirect old service URLs to new clean structure
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^service/invisible-grills/?$ /invisible-grills [R=301,L]
  RewriteRule ^service/invisible-grills-balcony/?$ /invisible-grills-balcony [R=301,L]
  RewriteRule ^service/invisible-grills-windows/?$ /invisible-grills-windows [R=301,L]
  RewriteRule ^service/invisible-grills-dealer/?$ /invisible-grills-dealer [R=301,L]
  RewriteRule ^service/ceiling-cloth-hanger/?$ /ceiling-cloth-hanger [R=301,L]
  RewriteRule ^services/invisible-grills/?$ /invisible-grills [R=301,L]
  RewriteRule ^services/invisible-grills-balcony/?$ /invisible-grills-balcony [R=301,L]
  RewriteRule ^services/invisible-grills-windows/?$ /invisible-grills-windows [R=301,L]
  RewriteRule ^services/invisible-grills-dealer/?$ /invisible-grills-dealer [R=301,L]
  RewriteRule ^services/ceiling-cloth-hanger/?$ /ceiling-cloth-hanger [R=301,L]
  
  # Redirect location pages to clean URLs
  RewriteRule ^locations/invisible-grills-(.+)/?$ /invisible-grills-$1 [R=301,L]
  RewriteRule ^location/invisible-grills-(.+)/?$ /invisible-grills-$1 [R=301,L]
  RewriteRule ^service-location/(.+)/?$ /$1 [R=301,L]
</IfModule>

# ============================================
# SECURITY HEADERS & CONFIGURATION
# ============================================

# Enable mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Remove .html extension from URLs (SPA routing)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html?url=$1 [QSA,L]

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove www prefix (redirect to non-www)
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================
# SECURITY HEADERS
# ============================================

<IfModule mod_headers.c>
  # Content Security Policy (CSP)
  # Prevents XSS attacks, clickjacking, and other injection attacks
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https:; frame-ancestors 'none'"

  # X-Frame-Options prevents clickjacking
  Header set X-Frame-Options "DENY"

  # X-Content-Type-Options prevents MIME type sniffing
  Header set X-Content-Type-Options "nosniff"

  # X-XSS-Protection enables browser XSS protection
  Header set X-XSS-Protection "1; mode=block"

  # Referrer Policy controls how much referrer info is shared
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy (formerly Feature Policy)
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # HSTS (HTTP Strict Transport Security)
  # Enforce HTTPS for 1 year including subdomains
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Remove Server header for security
  Header unset Server
  Header unset X-Powered-By
  Header unset X-AspNet-Version

  # Additional security headers
  Header set X-Permitted-Cross-Domain-Policies "none"
</IfModule>

# ============================================
# FILE TYPE PROTECTION
# ============================================

# Prevent access to sensitive files
<FilesMatch "(^#.*#|\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist|json)$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Block access to htaccess files
<Files .htaccess>
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# Block access to environment files
<Files ~ "\.env.*$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# ============================================
# CACHING STRATEGIES
# ============================================

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Cache images for 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # Cache CSS and JS for 6 months
  ExpiresByType text/css "access plus 6 months"
  ExpiresByType application/javascript "access plus 6 months"
  ExpiresByType text/javascript "access plus 6 months"
  
  # Cache fonts for 1 year
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  
  # HTML should not be cached
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Use ETag for cache validation
  <FilesMatch "\\.(jpg|jpeg|png|gif|webp|svg)$">
    Header set Cache-Control "max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\\.(css|js)$">
    Header set Cache-Control "max-age=15778800, immutable"
  </FilesMatch>

  <FilesMatch "\\.html$">
    Header set Cache-Control "max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================
# COMPRESSION
# ============================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
</IfModule>

# ============================================
# IMAGE DOWNLOAD PROTECTION
# ============================================

# Prevent direct image viewing and downloading
<FilesMatch "\.(jpg|jpeg|png|gif|webp|bmp|svg|ico)$">
  <IfModule mod_headers.c>
    # Prevent image from being saved/downloaded
    Header set Content-Disposition "attachment; filename=image"
    
    # Add anti-right-click header (works with client-side JS)
    Header set X-Content-Type-Options "nosniff"
  </IfModule>
</FilesMatch>

# ============================================
# DENY HOTLINKING
# ============================================

<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https?://prasannagrills\.com [NC]
  RewriteCond %{HTTP_REFERER} !^https?://www\.prasannagrills\.com [NC]
  RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC]
</IfModule>

# ============================================
# DEFAULT DIRECTORY PAGES
# ============================================

DirectoryIndex index.html index.htm

# ============================================
# PERFORMANCE OPTIMIZATIONS
# ============================================

# Enable GZIP compression
<IfModule mod_gzip.c>
  mod_gzip_on Yes
  mod_gzip_dechunk Yes
  mod_gzip_item_include file \.(html?|txt|css|js|json)$
  mod_gzip_item_include handler ^cgi-script$
  mod_gzip_item_include mime ^text/.*
  mod_gzip_item_include mime ^application/json$
  mod_gzip_minimum_file_size 500
</IfModule>
